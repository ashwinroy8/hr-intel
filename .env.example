# ─────────────────────────────────────────
# HR Intel — Environment Variables
# Copy this to .env and fill in your keys
# ─────────────────────────────────────────

# REQUIRED: Claude AI for people extraction
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL: NewsAPI for broader news coverage (free tier: 100 req/day)
# Get from: https://newsapi.org/register
# Leave empty to use RSS feeds only (still works great)
NEWSAPI_KEY=

# OPTIONAL: Apollo.io for email + phone enrichment (primary)
# Get from: https://app.apollo.io/#/settings/integrations/api
# Free tier: 50 email credits/month
APOLLO_API_KEY=

# OPTIONAL: Hunter.io for email enrichment (fallback if Apollo misses)
# Get from: https://hunter.io/api-keys
# Free tier: 25 searches/month
HUNTER_API_KEY=

# Security: change this to a long random string in production
SECRET_KEY=change-me-to-a-long-random-secret

# Database path (default: hr_intel.db in project root)
DB_PATH=hr_intel.db
